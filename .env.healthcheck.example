# Copy this file to .env.healthcheck and fill in your values.
# This file is intentionally NOT committed — add .env.healthcheck to .gitignore.

# ── Discord / Slack webhook URL ───────────────────────────────────────────────
# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
# Slack:   App Directory → Incoming Webhooks → Add to Slack → Copy URL
HEALTHCHECK_WEBHOOK_URL=

# "discord" | "slack" | "generic"
HEALTHCHECK_WEBHOOK_TYPE=discord
